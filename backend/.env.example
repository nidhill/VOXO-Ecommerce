# Server
PORT=5001

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
REFRESH_TOKEN_SECRET=
NODE_ENV=production

# Frontend URL (used in CORS allowlist and email links)
FRONTEND_URL=https://your-app.vercel.app

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=

# Resend email — https://resend.com/api-keys
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev

# Cloudflare R2 storage — https://dash.cloudflare.com/
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
